#include <iostream>
#include <string>
#include <map>
#include <set>
#include <stdbool.h>
#include <vector>
#include <algorithm>
#include <cstring>
#include <fstream>
using namespace std;
int main()
{
    int m;
    cin >> m;
    while (m--)
    {
        int matran[105][105], a, b;
        int dem = 0;
        cin >> a >> b;
        for (int i = 0; i < a; i++)
        {
            for (int j = 0; j < b; j++)
            {
                cin >> matran[i][j];
            }
        }
        for (int i = 0; i < a; i++)
        {
            for (int j = 0; j < b; j++)
            {
                if (i - 1 >= 0 && matran[i][j] == 1)
                {
                    matran[i][j] = matran[i - 1][j] + 1;
                }
            }
        }
        for (int i = 0; i < a; i++)
        {
            sort(matran[i], matran[i] + b, greater<int>());
        }
        for (int i = 0; i < a; i++)
        {
            int tmp = 0;
            for (int j = 0; j < b; j++)
            {
                tmp = matran[i][j] * (j + 1);
                dem = max(dem, tmp);
            }
        }
        cout << dem << endl;
    }
}
