#include <iostream>
#include <string>
#include <map>
#include <set>
#include <stdbool.h>
#include <vector>
#include <algorithm>
#include <cstring>
#include <fstream>
using namespace std;
int main()
{
    int m;
    cin >> m;
    while (m--)
    {
        int n, maxx = 0;
        cin >> n;
        int a[n], b[n];
        for (int &i : a)
            cin >> i;
        for (int &i : b)
            cin >> i;
        for (int i = 0; i < n; i++)
        {
            int tmp1 = 0, tmp2 = 0, tmp3 = 0;
            for (int j = i; j < n; j++)
            {
                tmp1 += a[j];
                tmp2 += b[j];
                if (tmp1 == tmp2)
                {
                    tmp3 = j - i + 1;
                    maxx = max(maxx, tmp3);
                }
            }
        }
        cout << maxx << endl;
    }
}
